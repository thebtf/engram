# Engram — Environment Configuration
# Copy to .env and edit: cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# Server port (worker + MCP SSE on single port)
WORKER_PORT=37777

# Authentication (empty = no auth; set for production)
API_TOKEN=

# Embedding provider: "openai" (OpenAI-compatible REST API)
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=http://localhost:4000/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=openai/Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSIONS=4096
EMBEDDING_TRUNCATE=true

# LLM for observation extraction (OpenAI-compatible endpoint)
# Required for Docker deployments where Claude CLI is not available.
# Falls back to EMBEDDING_BASE_URL if ENGRAM_LLM_URL is not set.
ENGRAM_LLM_URL=http://localhost:4000
ENGRAM_LLM_API_KEY=
ENGRAM_LLM_MODEL=gpt-4o-mini

# Optional: FalkorDB graph backend (uncomment falkordb service in docker-compose.yml)
# GRAPH_PROVIDER=falkordb
# FALKORDB_ADDR=falkordb:6379
# FALKORDB_PASSWORD=
# FALKORDB_GRAPH_NAME=engram
# FALKORDB_PORT=6379
