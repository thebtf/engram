{
  "name": "engram",
  "version": "0.2.0",
  "description": "OpenClaw plugin that connects to engram persistent memory server",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
