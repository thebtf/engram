  ],
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ]
